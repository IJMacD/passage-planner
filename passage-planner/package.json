{
  "name": "static-mapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "mediabunny": "^1.34.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^7.3.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:library": "tsc && vite --config vite.config.lib.js build",
    "deploy:library": "mkdir -p ../logbook/src/static/vendor && rsync -av dist/ ../logbook/src/static/vendor/"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.6.3"
  }
}
