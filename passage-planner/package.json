{
  "name": "static-mapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^12.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "mediabunny": "^1.34.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.4.21"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "proxy": "lcp --proxyUrl https://data.aishub.net",
    "build:library": "tsc && vite --config vite.config.lib.js build",
    "deploy:library": "mkdir -p ../logbook/src/static/vendor && rsync -av dist/ ../logbook/src/static/vendor/"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "sass-embedded": "^1.97.3",
    "typescript": "^5.6.3"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  }
}
